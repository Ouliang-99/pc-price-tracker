# PC Price Tracker — environment config
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าที่ขาด (อย่างน้อย APIFY_TOKEN)

# --- Apify ---
APIFY_TOKEN=

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
# context window — system prompt + few-shot + โพสยาวๆ กิน ~5-6k token อย่าต่ำกว่า 8192
OLLAMA_NUM_CTX=8192

# --- Alert ---
# alert เมื่อราคา < ALERT_THRESHOLD × avg (0.85 = ถูกกว่า avg 15%+)
ALERT_THRESHOLD=0.85

# --- Scraper intervals (ชั่วโมง) ---
SCRAPER_A_INTERVAL_HOURS=6
SCRAPER_B_INTERVAL_HOURS=1

# --- Web ---
FLASK_PORT=5000

# --- Location (คั่นด้วย comma) ใช้ flag "รับมือได้" (แมตช์ในข้อความโพส) ---
LOCATION_KEYWORDS=ปากเกร็ด,นนทบุรี,กรุงเทพ,ปทุมธานี,สมุทรปราการ,นครปฐม

# --- Apify actor IDs ---
APIFY_ACTOR_GROUPS=apify/facebook-groups-scraper
APIFY_ACTOR_MARKETPLACE=apify/facebook-marketplace-scraper

# --- Apify input (คั่นด้วย comma) ---
# URL ของกลุ่ม Facebook (public) ที่จะ scrape (Scraper A)
FB_GROUP_URLS=
# คำค้นสินค้าใน Marketplace (Scraper B) — ไม่เกี่ยวกับตำแหน่ง
MARKETPLACE_SEARCH_TERMS=RTX,Ryzen,DDR5
# ตำแหน่ง Marketplace (ฝังใน path ของ URL) เช่น "bangkok" หรือ numeric place id
MARKETPLACE_LOCATION=bangkok
# (ทางเลือก) URL marketplace เต็มที่ก็อปจาก browser — ตั้งแล้วจะ override location+terms
MARKETPLACE_SEARCH_URLS=
# กรองเฉพาะโพสใหม่กว่า (เช่น "14 days", "2025-01-01") — ว่าง = ทั้งหมด
POSTS_NEWER_THAN=
# เปิดหน้า listing ทีละอัน (1=เปิด กิน Apify traffic เยอะ, 0=ปิด ประหยัด) แนะนำ 0
MARKETPLACE_LISTING_DETAILS=0
# จำนวนโพสสูงสุดต่อรอบ scrape (ต่อ 1 คำค้น)
MAX_POSTS_PER_RUN=50
